# WoG MMORPG — Environment Variables
# Copy to shard/.env and fill in values before running

# ── Claude API ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Agent Wallets (HD derivation) ───────────────────────────
AGENT_SEED_PHRASE="your twelve or twenty-four word seed phrase here"

# ── Stacks Blockchain ───────────────────────────────────────
STACKS_NETWORK=testnet                          # testnet | mainnet

# Server wallet (signs all blockchain transactions)
# Get private key by importing mnemonic into a Stacks wallet
SERVER_PRIVATE_KEY=your_server_private_key_hex
SERVER_STACKS_ADDRESS=ST1XXXXXXXXXXXXXXXXXXXX

# Contract addresses (fill in after deploying .clar contracts)
# Deploy via: https://platform.hiro.so
GOLD_CONTRACT_ADDRESS=ST1XXXXXXXXXXXXXXXXXXXX
CHARACTER_CONTRACT_ADDRESS=ST1XXXXXXXXXXXXXXXXXXXX
ITEMS_CONTRACT_ADDRESS=ST1XXXXXXXXXXXXXXXXXXXX
SPRINT_CONTRACT_ADDRESS=ST1XXXXXXXXXXXXXXXXXXXX

# ── x402 Payments ─────────────────────────────────────────
X402_FACILITATOR_URL=https://x402.org/facilitator

# ── Sprint Config ──────────────────────────────────────────
SPRINT_SUBMIT_INTERVAL=20                       # ticks between score submissions

# ── Game Config ─────────────────────────────────────────────
AGENT_COUNT=3                                   # 1-5 agents
PORT=3000
SHARD_SERVER_URL=http://localhost:3000           # used by agent process

# ── Deployment ──────────────────────────────────────────────
# Set DOMAIN for Caddy HTTPS (e.g., wog.yourdomain.com)
# Leave unset for local dev (HTTP only)
# DOMAIN=wog.yourdomain.com

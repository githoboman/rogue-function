# WoG MMORPG — Environment Variables
# Copy to .env and fill in your values

# ── Claude API ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Agent Wallets (HD derivation) ───────────────────────────
AGENT_SEED_PHRASE="your twelve word seed phrase here for HD wallet derivation"

# ── Stacks Blockchain ───────────────────────────────────────
STACKS_NETWORK=testnet

# Server (realm) wallet — deploy contracts + mint properties from this address
# Get private key: import mnemonic into Leather/Xverse → export private key
SERVER_PRIVATE_KEY=your_64_char_hex_private_key
SERVER_STACKS_ADDRESS=ST...your_stacks_address

# Deployed contract addresses (all deployed from SERVER_STACKS_ADDRESS)
GOLD_CONTRACT_ADDRESS=ST...
CHARACTER_CONTRACT_ADDRESS=ST...
ITEMS_CONTRACT_ADDRESS=ST...
SPRINT_CONTRACT_ADDRESS=ST...
PROPERTY_CONTRACT_ADDRESS=ST...

# ── x402 Payments ─────────────────────────────────────────
X402_FACILITATOR_URL=https://x402.org/facilitator

# ── Sprint Config ──────────────────────────────────────────
SPRINT_SUBMIT_INTERVAL=20

# ── Game Config ─────────────────────────────────────────────
AGENT_COUNT=3
PORT=3001
SHARD_SERVER_URL=http://localhost:3001

# ── Frontend ─────────────────────────────────────────────────
VITE_WS_URL=ws://localhost:3001/ws

# ── FoxMQ (Tashi Vertex consensus broker) ───────────────────
# Download: github.com/tashigg/foxmq/releases
# Run: foxmq.exe --allow-anonymous-login --mqtt-addr=127.0.0.1:1883
FOXMQ_HOST=127.0.0.1
FOXMQ_PORT=1883
FOXMQ_USERNAME=wogagent
FOXMQ_PASSWORD=wogpass123

# ── aibtc.news Correspondent ────────────────────────────────
# BIP-137 signing for signal submission
# Signing key = your Bitcoin private key (WIF format)
AIBTC_SIGNING_KEY=your_wif_bitcoin_private_key
AIBTC_BEAT_SLUG=agent-economy
